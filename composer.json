{
  "name": "wavevision/di-service-annotation",
  "description": "Register DI services using annotation for Nette Framework.",
  "type": "library",
  "license": "MIT",
  "authors": [
    {
      "name": "Wavevision s.r.o.",
      "email": "info@wavevision.com"
    },
    {
      "name": "Jakub Filla",
      "email": "jakub.filla@wavevision.com"
    },
    {
      "name": "Vít Rozsíval",
      "email": "vit@wavevision.com"
    }
  ],
  "repositories": [
    {
      "type": "vcs",
      "url": "https://github.com/SimplikoCZ/wavevision-utils"
    }
  ],
  "autoload": {
    "psr-4": {
      "Wavevision\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Wavevision\\": "tests/"
    }
  },
  "config": {
    "sort-packages": true,
    "allow-plugins": {
      "dealerdirect/phpcodesniffer-composer-installer": true
    }
  },
  "require": {
    "php": "^8.5",
    "doctrine/annotations": "^2.0",
    "nette/finder": "^3.0",
    "wavevision/utils": "dev-master"
  },
  "require-dev": {
    "mikey179/vfsstream": "^1.6.8",
    "php-coveralls/php-coveralls": "^2.7",
    "phpunit/phpunit": "^11.0",
    "wavevision/coding-standard": "^6.0"
  },
  "extra": {
    "phpstan": {}
  }
}
